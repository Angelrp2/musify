# JWT — cambia este valor antes de poner en producción (mínimo 32 caracteres)
JWT_SECRET=change-me-in-production-min-32-chars

# Base de datos SQLite
DB_PATH=../database/musify.db

# Ollama IA local (instalar desde https://ollama.ai)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# MusicBrainz (no necesita clave — API pública)
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2

# Servidor
APP_URL=http://localhost:8000
APP_ENV=development

# Spotify (opcional — para reproductor externo)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
